# Copiar a `.env` y completar valores locales / producción.

# PostgreSQL (Prisma)
# Ejemplo local: postgresql://USER:PASSWORD@localhost:5432/autostore?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/autostore?schema=public"

# Auth.js / NextAuth (v5 usa AUTH_*; se aceptan también las claves NEXTAUTH_* en código)
AUTH_URL="http://localhost:3000"
AUTH_SECRET="generar-con-openssl-rand-base64-32"
# Compatibilidad:
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="mismo-valor-que-AUTH_SECRET"

# Google OAuth (opcional: si están vacíos, el proveedor no se registra)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# WhatsApp público (solo dígitos, con código de país, ej. 573001234567)
NEXT_PUBLIC_WHATSAPP_NUMBER="573012345678"

# Semilla del primer usuario ADMIN (solo `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@delaespriella.local"
SEED_ADMIN_PASSWORD="CambiarLuego123!"

# Opcional: almacenamiento de archivos (fase de subida de imágenes)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# S3_BUCKET_NAME=""


# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Email para responder mensajes desde el admin
# Ejemplo con Gmail: usar contraseña de aplicación, no la normal
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM="Auto Store Motors <tu@gmail.com>"