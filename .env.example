# Copiar a `.env` y completar valores locales / producción.

# PostgreSQL (Prisma)
# Ejemplo local: postgresql://USER:PASSWORD@localhost:5432/autostore?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/autostore?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generar-con-openssl-rand-base64-32"

# Google OAuth (App Router)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Opcional: almacenamiento de archivos (fase de subida de imágenes)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION=""
# S3_BUCKET_NAME=""
