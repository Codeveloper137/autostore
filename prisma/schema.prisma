// De La Espriella Motors — PostgreSQL schema
// Capa de persistencia: modelos alineados al dominio del concesionario.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum UserRole {
  ADMIN
  CLIENT
}

enum QuoteStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

/// Clasificación de categorías (marca, modelo, etiquetas de inventario, etc.)
enum CategoryKind {
  BRAND
  MODEL
  TAG
}

enum Transmission {
  MANUAL
  AUTOMATIC
  SEMI_AUTOMATIC
  CVT
}

enum FuelType {
  GASOLINE
  DIESEL
  ELECTRIC
  HYBRID
  LPG
  OTHER
}

enum AnalyticsEventType {
  SITE_VIEW
  VEHICLE_VIEW
  PAGE_VIEW
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

/// Páginas de blog / contenido estático (CMS)
model ContentPage {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  excerpt     String?
  body        String        @db.Text
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, slug])
}

// --- Auth (NextAuth.js + extensión de rol) ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CLIENT)
  /// Hash bcrypt; solo usuarios con proveedor "credentials"
  passwordHash  String?

  accounts Account[]
  sessions Session[]

  quotes            Quote[]
  favorites         Favorite[]
  analyticsEvents   AnalyticsEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Inventario ---

model Category {
  id       String         @id @default(cuid())
  name     String
  slug     String         @unique
  kind     CategoryKind
  parentId String?
  parent   Category?      @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]     @relation("CategoryTree")

  vehiclesAsBrand Vehicle[] @relation("VehicleBrand")
  vehiclesAsModel Vehicle[] @relation("VehicleModel")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, slug])
}

model Vehicle {
  id           String       @id @default(cuid())
  /// Referencia interna de inventario (opcional)
  stockCode    String?      @unique

  brandId String
  modelId String
  brand   Category @relation("VehicleBrand", fields: [brandId], references: [id])
  model   Category @relation("VehicleModel", fields: [modelId], references: [id])

  year          Int
  mileageKm     Int
  transmission  Transmission
  color         String
  fuel          FuelType
  /// Precio en unidad mínima (ej. centavos) para evitar errores de punto flotante
  priceAmount   Int
  currency      String       @default("COP")

  title            String
  description      String       @db.Text
  shortDescription String?
  /// URLs de imágenes almacenadas (CDN, bucket, etc.)
  imageUrls        String[]

  published Boolean @default(false)

  quotes          Quote[]
  favorites       Favorite[]
  analyticsEvents AnalyticsEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, year])
  @@index([brandId, modelId])
}

// --- CRM / cotizaciones ---

model Quote {
  id        String      @id @default(cuid())
  vehicleId String?
  vehicle   Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  fullName String
  email    String
  phone    String?
  message  String      @db.Text
  status   QuoteStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// --- Cliente: favoritos ---

model Favorite {
  id        String @id @default(cuid())
  userId    String
  vehicleId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, vehicleId])
}

// --- Analítica ---

model AnalyticsEvent {
  id   String             @id @default(cuid())
  type AnalyticsEventType

  path      String?
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Identificador anónimo (cookie / session browser) cuando no hay usuario
  visitorKey String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([vehicleId, createdAt])
}
